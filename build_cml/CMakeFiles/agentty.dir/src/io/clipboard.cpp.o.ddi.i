try_clipboard_cmd_override(std::string* error_out, bool& clip_handled) {
    clip_handled = false;
    const char* cmd = util::env::get_or_null<util::env::Var::ClipboardCmd>();
    if (!cmd) return std::nullopt;
    clip_handled = true;
