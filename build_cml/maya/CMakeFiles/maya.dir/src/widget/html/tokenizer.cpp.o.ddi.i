        if (!is_space_or_tab(c) && c != '\n' && c != '\r') return false;
    return true;
}



[[nodiscard]] inline int leading_indent(std::string_view s, std::size_t& bytes) {
    int col = 0;
    std::size_t i = 0;
    for (; i < s.size(); ++i) {
        if (s[i] == ' ') ++col;
        else if (s[i] == '\t') col += 4 - (col % 4);
        else break;
    }
