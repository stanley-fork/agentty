[[nodiscard]] inline std::string ascii_lower(std::string_view s) {
    std::string out;
    out.reserve(s.size());
    for (char c : s) {
        if (c >= 'A' && c <= 'Z') c = static_cast<char>(c - 'A' + 'a');
        out += c;
    }
    return out;
}



[[nodiscard]] inline std::string_view lookup_case_fold(char32_t cp) noexcept {
    int lo = 0, hi = kCaseFoldCount - 1;
    while (lo <= hi) {
        int mid = (lo + hi) / 2;
