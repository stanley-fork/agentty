            float p = 2 * l - q;
            float hn = h / 360.0f;
            r = hue2rgb(p, q, hn + 1.0f/3);
            g = hue2rgb(p, q, hn);
            b = hue2rgb(p, q, hn - 1.0f/3);
        }
        return Color::rgb(
            static_cast<uint8_t>(r * 255 + 0.5f),
            static_cast<uint8_t>(g * 255 + 0.5f),
            static_cast<uint8_t>(b * 255 + 0.5f)
        );
    }


