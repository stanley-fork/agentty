public:

    constexpr Color() noexcept : kind_(Kind::Named), r_(7), g_(0), b_(0) {}

    constexpr explicit Color(AnsiColor c) noexcept
        : kind_(Kind::Named), r_(static_cast<uint8_t>(c)), g_(0), b_(0) {}


