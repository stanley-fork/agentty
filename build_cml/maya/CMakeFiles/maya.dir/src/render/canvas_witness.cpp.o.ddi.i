namespace detail {



[[nodiscard]] constexpr bool in_ranges(
    char32_t cp,
    std::span<const WidthRange> ranges) noexcept
{



    auto it = std::ranges::upper_bound(
        ranges, cp, {}, &WidthRange::first);
    if (it == ranges.begin()) return false;
    --it;
    return cp <= it->last;
}

}
