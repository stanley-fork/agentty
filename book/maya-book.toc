\contentsline {chapter}{\numberline {1}Hello, maya}{2}{chapter.1}%
\contentsline {section}{\numberline {1.1}What is a terminal? (the honest answer)}{2}{section.1.1}%
\contentsline {subsection}{\numberline {1.1.1}Why does it look so old?}{2}{subsection.1.1.1}%
\contentsline {section}{\numberline {1.2}What is a TUI?}{3}{section.1.2}%
\contentsline {subsection}{\numberline {1.2.1}Why bother with TUIs in 2025?}{3}{subsection.1.2.1}%
\contentsline {section}{\numberline {1.3}One frame of a TUI: what literally happens}{4}{section.1.3}%
\contentsline {paragraph}{1. The keyboard sends a byte to the kernel.}{4}{section.1.3}%
\contentsline {paragraph}{2. The terminal emulator forwards the byte.}{4}{section.1.3}%
\contentsline {paragraph}{3. The maya program reads the byte.}{4}{section.1.3}%
\contentsline {paragraph}{4. Maya turns the byte into an Event.}{4}{section.1.3}%
\contentsline {paragraph}{5. Your code computes a new state.}{4}{section.1.3}%
\contentsline {paragraph}{6. Maya turns the new state into an Element tree.}{4}{section.1.3}%
\contentsline {paragraph}{7. The layout engine assigns positions.}{4}{section.1.3}%
\contentsline {paragraph}{8. The renderer builds a virtual screen.}{5}{section.1.3}%
\contentsline {paragraph}{9. The differ finds what changed.}{5}{section.1.3}%
\contentsline {paragraph}{10. Maya emits ANSI bytes for only that cell.}{5}{section.1.3}%
\contentsline {paragraph}{11. Those bytes flow back through the pty to the emulator.}{5}{section.1.3}%
