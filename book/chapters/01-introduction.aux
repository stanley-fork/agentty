\@writefile{toc}{\contentsline {paragraph}{1. The keyboard sends a byte to the kernel.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{2. The terminal emulator forwards the byte.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{3. The maya program reads the byte.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{4. Maya turns the byte into an Event.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{5. Your code computes a new state.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{6. Maya turns the new state into an Element tree.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{7. The layout engine assigns positions.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{8. The renderer builds a virtual screen.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{9. The differ finds what changed.}{4}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{10. Maya emits ANSI bytes for only that cell.}{5}{section.1.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{11. Those bytes flow back through the pty to the emulator.}{5}{section.1.3}\protected@file@percent }
